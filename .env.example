# SynapseHub Environment Variables
# Copy this file to .env and fill in your values

# Gemini AI API Key (get from https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=

# Webhook URL for lead capture (your CRM/automation endpoint)
VITE_WEBHOOK_URL=

# Supabase (for dashboard/auth — Phase 2)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Tag Manager ID (e.g., GTM-XXXXXXX)
VITE_GTM_ID=

# Site URL
VITE_SITE_URL=https://synapsehub.net
