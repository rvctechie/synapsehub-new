# SynapseHub Environment Variables
# Copy this file to .env.local and fill in the actual values
# DO NOT commit .env.local to version control

# Google Gemini API Key (required for chat widget)
# Get your key from: https://aistudio.google.com/app/apikeys
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: API endpoint configurations
# VITE_API_BASE_URL=https://api.example.com
# VITE_WEBHOOK_URL=https://hooks.example.com
